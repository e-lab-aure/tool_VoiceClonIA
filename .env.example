# ============================================================
# Configuration de VoiceClonIA — copier ce fichier en .env
# et remplir les valeurs réelles (ne jamais committer .env)
# ============================================================

# Moteur TTS actif : "chatterbox" | "f5tts" | "voxtral"
TTS_ENGINE=chatterbox

# --- Voxtral (vLLM Omni) ---
# URL du serveur vLLM Omni (demarrer avec : vllm serve mistralai/Voxtral-4B-TTS-2603 --omni --port 8001)
VOXTRAL_SERVER_URL=http://127.0.0.1:8001
# Voix preset utilisee si aucun audio de reference n'est disponible
# Voix disponibles : casual_male, casual_female, cheerful_female, neutral_male, neutral_female,
#                    fr_male, fr_female, es_male, es_female, de_male, de_female,
#                    it_male, it_female, pt_male, pt_female, nl_male, nl_female
VOXTRAL_DEFAULT_VOICE=neutral_male

# Chemin vers le dossier de stockage des fichiers audio uploadés
UPLOAD_DIR=uploads

# Chemin vers le dossier de sortie des fichiers générés
OUTPUT_DIR=outputs

# Chemin vers le dossier des modèles fine-tunés XTTS-v2 (un sous-dossier par profil)
MODELS_DIR=models

# Chemin vers la base de données SQLite
DATABASE_PATH=data/voicelconia.db

# Niveau de log : DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Chemin du fichier de log
LOG_FILE=data/voicelconia.log

# Durée maximale autorisée d'un fichier audio en secondes (sécurité)
MAX_AUDIO_DURATION_SECONDS=300

# Taille maximale d'un fichier audio uploadé en Mo
MAX_UPLOAD_SIZE_MB=50

# Hôte et port du serveur FastAPI
HOST=127.0.0.1
PORT=8000
